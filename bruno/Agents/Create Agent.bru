meta {
  name: Create Agent
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/agents
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Novo Agente",
    "description": "Descricao do agente",
    "systemPrompt": "Voce e um assistente virtual",
    "chatModel": "gpt-4o",
    "collectName": false,
    "collectEmail": false,
    "collectPhone": false
  }
}
