meta {
  name: Update Agent
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/agents/:id
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:path {
  id: 1
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Agente Atualizado",
    "description": "Descricao atualizada",
    "systemPrompt": "Voce e um assistente virtual atualizado",
    "chatModel": "gpt-4o",
    "collectName": true,
    "collectEmail": true,
    "collectPhone": false
  }
}
