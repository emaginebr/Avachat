# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=avabot
CONNECTION_STRING=Host=db;Database=avabot;Username=postgres;Password=your_password_here

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Auth
AVABOT_USERNAME=admin
AVABOT_PASSWORD=your_password_here
AVABOT_JWT_SECRET=your_jwt_secret_min_32_chars_here

# WPP Connect
WPP_SECRET_KEY=your_wpp_secret_key_here

# App
APP_PORT=5000
