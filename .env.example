# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=avachat
CONNECTION_STRING=Host=db;Database=avachat;Username=postgres;Password=your_password_here

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Auth
AVACHAT_USERNAME=admin
AVACHAT_PASSWORD=your_password_here
AVACHAT_JWT_SECRET=your_jwt_secret_min_32_chars_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_AGENT_SLUG=your_agent_slug_here

# App
APP_PORT=5000
